<!DOCTYPE html>
<html lang="en">    
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheeets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
  <div class="w-full h-screen bg-zinc-900 text-white p-10">
    <h3 class="text-3xl font-semibold mb-3"> Hey User! Upload Files</h3>
    <form autocomplete="off" action="/upload" method="post"  enctype="multipart/form-data">
         <input
            class="border border-zinc-600 rounded-md p-2 file:bg-zinc-600 file:text-white file:border-0 file:px-4 file:py-2 file:mr-4"
            type="file"
            name="image"
        >
        <input class="px-2 py-2 bg-blue-600 rounded-md  font-semibold " type="submit" value="Upload File"/>
    </form>
           

  </div>
</body>
</html>