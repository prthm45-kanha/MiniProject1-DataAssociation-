<!DOCTYPE html>
<html lang="en">    
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheeets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
  <div class="w-full h-screen bg-zinc-900 text-white p-10 ">
        <div class="flex justify-end w-full">
            <a class=" bg-red-500 px-3 rounded-md py-2 font-semibold text-sm mb-3 inline-block " href="/logout">Logout</a>
        </div>
        <div class="flex items-start gap-3">
            <div class="w-14 h-14 overflow-hidden rounded-full ">
                <img class="w-full h-full object-cover" src="/images/uploads/<%= useer.profilepic %>">
            </div>
       <h3 class="text-3xl font-semibold mb-3 tracking-tighter"> <span class="text-pink-700">Hey,</span> <%= useer.name %>! Welcome to Your Profile</h3>
        </div>
    <h5>You can create a new post</h5>
    <form action="/post" method="post">
        <textarea placeholder="What's on your Mind" class="w-1/3 block px-3 py-3 resize-none bg-transparent border-[1px] outline-none border-zinc-600 rounded-md mt-3" name="contentt"></textarea>
        <input class="px-3 py-2  rounded-md text-sm font-bold block bg-blue-600 mt-3 " type="submit" value="Create a New Post"/>
    </form>
    <div class="posts mt-8 overflow-x-auto"> 
        <h3 class="text-zinc-400">Your Posts.</h3>
        <div class="postcontainer  flex gap-2 flex-nowrap  mt-5">

            <% useer.posts.reverse().forEach(function(post){ %>
                <div class="post shrink-0 w-1/3 p-3 border-[1px] border-zinc-600 bg-zinc-800 rounded-md">
                <h4 class="text-blue-500 mb-2">@<%= useer.username %></h4>
                <p class="text-sm tracking-tight "><%= post.content %></p>
                <small class="mt-2 inline-block"><%= post.likes.length %>likes</small>
                <div class="btns flex gap-4 mt-5">
                    <a class="text-emerald-600 text-lg" href="/like/<%= post._id %>">
                        <%= post.likes.indexOf(useer._id) === -1 ? "Like" :"Unlike" %>
                    </a>
                    <a class="text-zinc-600 text-lg" href="/edit/<%= post._id %>">Edit</a>
                </div>
            </div>                
           <% })%>

        </div>
    </div>
    <a class="text-blue-600 text-xl mt-4 inline-block" href="/">Back to Home</a>


  </div>

</body>
</html>