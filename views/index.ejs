<!DOCTYPE html>
<html lang="en">    
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheeets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
  <div class="w-full h-screen bg-zinc-900 text-white p-10">
    <h3 class="text-3xl font-semibold mb-3"> Hey User! Create Account</h3>
    <form autocomplete="off" action="/register" method="post">
        <input class="bg-transparent px-3 py-2 border-2 border-zinc-600 outline-none rounded-md" type="text" placeholder="Enter Username" name="username"/>
        <input class="bg-transparent px-3 py-2 border-2 border-zinc-600 outline-none rounded-md" type="text" placeholder="Enter Name" name="name"/>
        <input class="bg-transparent px-3 py-2 border-2 border-zinc-600 outline-none rounded-md" type="number" placeholder="Enter Age" name="age"/>
        <input class="bg-transparent px-3 py-2 border-2 border-zinc-600 outline-none rounded-md" type="email" placeholder="Enter Email" name="email"/>
        <input class="bg-transparent px-3 py-2 border-2 border-zinc-600 outline-none rounded-md" type="text" placeholder="Enter Password" name="password"/>
        <input class="px-2 py-2 bg-blue-600 rounded-md  font-semibold " type="submit" value="Sign Up"/>
    </form>
           <h3 class="text-3xl font-semibold mt-3 mb-3"> Already Register?</h3>
                           <a class=" bg-emerald-600 px-3 rounded-md py-2 font-semibold " href="/login">Sign In</a>
                           <a class=" bg-pink-600 px-3 rounded-md py-2 ml-[20px] font-semibold " href="/profile">Go to your Profile</a>
                           <a class=" bg-yellow-600 px-3 rounded-md py-2 ml-[20px] font-semibold " href="/profile/upload">Upload File</a>
                           


  </div>
</body>
</html>