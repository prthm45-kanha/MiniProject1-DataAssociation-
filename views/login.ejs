<!DOCTYPE html>
<html lang="en">    
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheeets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
  <div class="w-full h-screen bg-zinc-900 text-white p-10">
    <h3 class="text-3xl font-semibold mb-3"> Hey User! Login into your Account</h3>
    <form action="/login" method="post">
       
        <input class="bg-transparent px-3 py-2 border-2 border-zinc-600 outline-none rounded-md" type="email" placeholder="Enter Email" name="email"/>
        <input class="bg-transparent px-3 py-2 border-2 border-zinc-600 outline-none rounded-md" type="text" placeholder="Enter Password" name="password"/>
        <input class="px-2 py-2 bg-yellow-600 ml-3 rounded-md  font-semibold " type="submit" value="Sign In"/>
        

                
    </form>
    <a class=" bg-red-600 px-3 rounded-md py-2 font-semibold " href="/logout">Logout User</a>
    <a class="text-blue-600 text-xl mt-4 inline-block" href="/">Back to Home</a>

  </div>
</body>
</html>